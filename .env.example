# ═══════════════════════════════════════════════════════════════════
# Supabase Production for EasyPanel — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
#
# Setup:
#   1. cp .env.example .env
#   2. ./scripts/generate-secrets.sh   (generates all secrets below)
#   3. Fill in SMTP and OAuth credentials if needed
#   4. ./scripts/install.sh
#
# NEVER commit .env to version control!

# ═══════════════════════════════════════════════════════════════════
# 1. Secrets — Run ./scripts/generate-secrets.sh to populate
# ═══════════════════════════════════════════════════════════════════

# PostgreSQL superuser password (min 32 chars)
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password

# JWT signing secret for auth tokens (min 32 chars)
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Session/CSRF encryption key (min 64 chars)
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq

# Vault encryption key for secrets at rest (exactly 32 chars)
VAULT_ENC_KEY=your-32-character-encryption-key

# Postgres Meta crypto key for dashboard (min 32 chars)
PG_META_CRYPTO_KEY=your-encryption-key-32-chars-min

# Public API key for client-side use (JWT — generated by generate-secrets.sh)
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzAwMDAwMDAwLCJleHAiOjQ4NTU1NjAwMDB9.changeme

# Admin API key for server-side use (JWT — generated by generate-secrets.sh)
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE3MDAwMDAwMDAsImV4cCI6NDg1NTU2MDAwMH0.changeme

# ═══════════════════════════════════════════════════════════════════
# 2. URLs — Domains exposed via Cloudflare Tunnel
# ═══════════════════════════════════════════════════════════════════

# Public API URL (Kong gateway)
SUPABASE_PUBLIC_URL=https://supabase.mlluizdevtech.com.br

# External URL for auth callbacks (OAuth redirects, email links)
API_EXTERNAL_URL=https://supabase.mlluizdevtech.com.br

# Studio dashboard URL
STUDIO_URL=https://studio.mlluizdevtech.com.br

# Site URL for authentication redirects (must match Studio domain)
SITE_URL=https://studio.mlluizdevtech.com.br

# ═══════════════════════════════════════════════════════════════════
# 3. Database — PostgreSQL connection settings
# ═══════════════════════════════════════════════════════════════════

# Database name (default: postgres)
POSTGRES_DB=postgres

# ═══════════════════════════════════════════════════════════════════
# 4. Connection Pooling — Supavisor
# ═══════════════════════════════════════════════════════════════════

# Unique identifier for this tenant
POOLER_TENANT_ID=supabase-tenant

# Max PostgreSQL connections per pool
POOLER_DEFAULT_POOL_SIZE=20

# Max client connections per pool
POOLER_MAX_CLIENT_CONN=100

# ═══════════════════════════════════════════════════════════════════
# 5. Authentication — GoTrue
# ═══════════════════════════════════════════════════════════════════

# JWT token expiry in seconds (default: 3600 = 1 hour)
JWT_EXPIRY=3600

# Allow email/password authentication
GOTRUE_EXTERNAL_EMAIL_ENABLED=true

# Auto-confirm email addresses (set to true to skip email verification)
GOTRUE_MAILER_AUTOCONFIRM=false

# Allow anonymous sign-ins
GOTRUE_EXTERNAL_ANONYMOUS_USERS_ENABLED=false

# Allowed redirect URIs (comma-separated, leave empty for Studio only)
GOTRUE_URI_ALLOW_LIST=

# Database pool size for auth
GOTRUE_DB_MAX_POOL_SIZE=20

# ═══════════════════════════════════════════════════════════════════
# 5a. OAuth Providers — Uncomment and fill to enable
# ═══════════════════════════════════════════════════════════════════

# GitHub OAuth
GOTRUE_EXTERNAL_GITHUB_ENABLED=false
GOTRUE_EXTERNAL_GITHUB_CLIENT_ID=
GOTRUE_EXTERNAL_GITHUB_SECRET=

# Google OAuth
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=

# ═══════════════════════════════════════════════════════════════════
# 6. SMTP — Email delivery for auth (magic links, invitations, etc.)
# ═══════════════════════════════════════════════════════════════════
#
# Without SMTP configured, password reset and email verification
# will NOT work. Use any transactional email provider:
#   - Resend (resend.com)        — free tier: 100 emails/day
#   - SendGrid (sendgrid.com)    — free tier: 100 emails/day
#   - Brevo (brevo.com)          — free tier: 300 emails/day

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Supabase
SMTP_ADMIN_EMAIL=

# ═══════════════════════════════════════════════════════════════════
# 7. REST API — PostgREST
# ═══════════════════════════════════════════════════════════════════

# Database schemas exposed via REST API
PGRST_DB_SCHEMAS=public,storage,graphql_public

# Max rows returned per query
PGRST_DB_MAX_ROWS=1000

# Database connection pool size
PGRST_DB_POOL=10

# Log level: info, notice, warning, error
PGRST_LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════
# 8. Storage — File upload/download
# ═══════════════════════════════════════════════════════════════════

# Storage backend: file (local) or s3 (S3-compatible)
STORAGE_BACKEND=file

# S3 bucket name (used even with file backend for compatibility)
STORAGE_BUCKET=supabase-storage

# Storage region identifier
STORAGE_REGION=local

# Max upload file size in bytes (default: 50 MB)
STORAGE_FILE_SIZE_LIMIT=52428800

# Database pool size for storage
STORAGE_DB_POOL_SIZE=10

# ═══════════════════════════════════════════════════════════════════
# 9. Image Proxy — ImgProxy (on-the-fly image transformation)
# ═══════════════════════════════════════════════════════════════════

# Signature key and salt for URL signing (leave empty to disable signing)
# Generate with: openssl rand -hex 32
IMGPROXY_KEY=
IMGPROXY_SALT=

# ═══════════════════════════════════════════════════════════════════
# 10. Metadata API — Postgres Meta
# ═══════════════════════════════════════════════════════════════════

PG_META_DB_MAX_POOL_SIZE=5

# ═══════════════════════════════════════════════════════════════════
# 11. API Gateway — Kong
# ═══════════════════════════════════════════════════════════════════

# Log level: debug, info, notice, warn, error, crit, alert, emerg
KONG_LOG_LEVEL=notice

# Max request body size (e.g., 50m for file uploads through Kong)
KONG_CLIENT_MAX_BODY_SIZE=50m

# ═══════════════════════════════════════════════════════════════════
# 12. Dashboard — Supabase Studio
# ═══════════════════════════════════════════════════════════════════

STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project

# ═══════════════════════════════════════════════════════════════════
# 13. External Access
# ═══════════════════════════════════════════════════════════════════
#
# Use EasyPanel's built-in reverse proxy (Traefik/Caddy) to expose:
#   Studio → http://supabase-studio:3000
#   API    → http://supabase-kong:8000
